<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Supermarket Admin</title>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand">Supermarket Admin</a>
            <a href="/add" class="btn btn-primary">Add New Product</a>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <% products.forEach(product => { %>
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="/uploads/<%= product.image %>" class="card-img-top" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title"><%= product.name %></h5>
                            <p class="text-muted"><%= product.category %></p>
                            <h4 class="text-primary"><%= product.price %> บาท</h4>
                            <p class="<%= product.stock == 0 ? 'text-danger fw-bold' : '' %>">
                                Stock: <%= product.stock == 0 ? 'Out of Stock' : product.stock %>
                            </p>
                            <div class="d-flex justify-content-between">
                                <a href="/edit/<%= product.id %>" class="btn btn-sm btn-info">Edit</a>
                                <form action="/delete/<%= product.id %>" method="POST" onsubmit="return confirm('คุณแน่ใจหรือไม่ว่าต้องการลบรายการนี้?')">
                                    <button class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>