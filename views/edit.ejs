<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product - Supermarket Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-info text-white">
                        <h4 class="mb-0">แก้ไขข้อมูลสินค้า</h4>
                    </div>
                    <div class="card-body">
                        <form action="/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label">ชื่อสินค้า</label>
                                <input type="text" name="name" class="form-control" value="<%= product.name %>" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">หมวดหมู่</label>
                                <input type="text" name="category" class="form-control" value="<%= product.category %>">
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">ราคา (บาท)</label>
                                    <input type="number" name="price" class="form-control" step="0.01" min="0" value="<%= product.price %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">จำนวนสต็อก</label>
                                    <input type="number" name="stock" class="form-control" min="0" value="<%= product.stock %>" required>
                                </div>
                            </div>
                            <div class="mb-3 text-center">
                                <label class="form-label d-block text-start">รูปภาพปัจจุบัน</label>
                                <img src="/uploads/<%= product.image %>" class="img-thumbnail mb-2" style="height: 150px;">
                                <input type="file" name="image" class="form-control" accept="image/*">
                                <small class="text-muted text-start d-block mt-1">*เลือกไฟล์ใหม่หากต้องการเปลี่ยนรูปภาพ</small>
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-info text-white">อัปเดตข้อมูล</button>
                                <a href="/" class="btn btn-secondary">ยกเลิก</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>